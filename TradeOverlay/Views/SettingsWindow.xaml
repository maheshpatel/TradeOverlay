<Window x:Class="TradeOverlay.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:TradeOverlay.Converters"
        Title="Settings — Trade Overlay"
        Width="400"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
    </Window.Resources>

    <Border CornerRadius="10"
            Background="{StaticResource BackgroundBrush}"
            BorderBrush="{StaticResource AppBorderBrush}"
            BorderThickness="1">
        <StackPanel Margin="16,14,16,16">

            <!-- Title bar -->
            <Grid Margin="0,0,0,12">
                <TextBlock Text="⚙  Settings"
                           Foreground="{StaticResource GoldBrush}"
                           FontSize="14" FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <Button HorizontalAlignment="Right"
                        Style="{StaticResource FlatButton}"
                        Content="✕"
                        Click="Close_Click"/>
            </Grid>

            <!-- ── Kite API Credentials ──────────────────────────────────── -->
            <TextBlock Text="KITE CONNECT CREDENTIALS"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>

            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <Label Content="API Key"/>
                    <TextBox Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <Label Content="API Secret"/>
                    <PasswordBox x:Name="ApiSecretBox" Margin="0,2,0,0"
                                 PasswordChanged="ApiSecretBox_PasswordChanged"/>
                </StackPanel>
            </Grid>

            <!-- Callback port -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <Label Content="Callback Port"/>
                    <TextBox Text="{Binding CallbackPort, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,0"/>
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="10" TextWrapping="Wrap"
                           VerticalAlignment="Bottom" Margin="10,0,0,4">
                    Set redirect URL in Kite developer portal to:
                    http://localhost:{port}/callback/
                </TextBlock>
            </Grid>

            <!-- Login button -->
            <Button Style="{StaticResource FlatButton}"
                    Background="#1A3A5C"
                    Command="{Binding LoginWithKiteCommand}"
                    IsEnabled="{Binding IsLoggingIn, Converter={StaticResource InvBoolToVis}}"
                    Margin="0,0,0,6"
                    Padding="10,8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🔐  Login with Kite (opens browser)"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                </StackPanel>
            </Button>

            <!-- Login status message -->
            <Border Background="#1A1A2E" CornerRadius="4" Padding="8,6"
                    Margin="0,0,0,8"
                    Visibility="{Binding LoginStatus, Converter={StaticResource StringNotEmptyToVis}}">
                <TextBlock Text="{Binding LoginStatus}"
                           FontSize="11" TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding LoginSuccess}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource GreenBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>

            <!-- Manual access token fallback -->
            <Expander Header="Manual access token (advanced)"
                      Foreground="{StaticResource TextSecondaryBrush}"
                      FontSize="10"
                      Margin="0,0,0,10">
                <StackPanel Margin="0,6,0,0">
                    <Label Content="Access Token"/>
                    <PasswordBox x:Name="AccessTokenBox"
                                 Margin="0,2,0,4"
                                 PasswordChanged="AccessTokenBox_PasswordChanged"/>
                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="10"
                               TextWrapping="Wrap">
                        Only needed if auto-login fails. Access tokens expire at 06:00 AM daily.
                    </TextBlock>
                </StackPanel>
            </Expander>

            <!-- ── Trade settings ─────────────────────────────────────────── -->
            <TextBlock Text="TRADE LIMITS &amp; RISK"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>

            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <Label Content="Max Trades Per Day"/>
                    <TextBox Text="{Binding MaxTradesPerDay, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <Label Content="Poll Interval (sec)"/>
                    <TextBox Text="{Binding PollingIntervalSeconds, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </Grid>

            <Label Content="Max Daily Loss (₹)"/>
            <TextBox Text="{Binding MaxDailyLossRupees, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,2,0,10"/>
            <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="10"
                       TextWrapping="Wrap" Margin="0,0,0,10">
                Alert fires and overlay turns red when total P&amp;L loss exceeds this amount.
            </TextBlock>

            <!-- ── Overlay ────────────────────────────────────────────────── -->
            <TextBlock Text="OVERLAY"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>

            <Label Content="Opacity (0.3 – 1.0)"/>
            <Slider Minimum="0.3" Maximum="1.0" TickFrequency="0.05"
                    Value="{Binding WindowOpacity}"
                    Foreground="{StaticResource AccentBrush}"
                    Margin="0,2,0,12"/>

            <!-- ── Actions ────────────────────────────────────────────────── -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Style="{StaticResource FlatButton}"
                        Margin="0,0,8,0" Click="Close_Click"/>
                <Button Content="Save &amp; Apply" Style="{StaticResource FlatButton}"
                        Background="{StaticResource AccentBrush}"
                        Command="{Binding SaveCommand}"
                        Click="Save_Click"/>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>
